# Public hostname Traefik routes Grafana to. Must resolve to this Coolify host.
# Loki is intentionally not exposed — only reachable inside the docker network.
GRAFANA_DOMAIN=grafana.example.com

# Grafana admin credentials. ADMIN_PASSWORD is REQUIRED — compose will refuse
# to start without it. Pick something long; reset later via Grafana UI.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-to-a-strong-password
